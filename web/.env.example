# Config Firebase: di default l'app usa quella pubblica hardcoded (vedi src/lib/firebase.ts).
# Questi override servono solo se vuoi puntare a un altro progetto Firebase.
# Solo le var con prefisso VITE_ finiscono nel bundle client.

VITE_FB_APIKEY=
VITE_FB_DB=

# Supabase (Fase 2) — pubbliche, finiscono nel bundle frontend.
# In produzione impostarle nelle Environment Variables di Vercel.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Metti a true per usare Supabase come backend (letture; la produzione resta Firebase finche non impostato).
VITE_USE_SUPABASE=
